#!/bin/bash
# Setup desktop environment
# - Boots to terminal (multi-user) by default
# - Disables screensaver / DPMS

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
    echo -e "\e[1;31mThis program must be run as root\e[0m"
    exit 1
fi

WALLPAPER="/usr/src/UX/res/logo/uxsplash.png"
START_ICON="/usr/src/UX/res/logo/logo-128.png"

echo "[*] Installing LXQt desktop environment..."
apt update -y
apt install -y lxqt lxqt-panel xorg xserver-xorg xinit qt5-style-kvantum gnome-icon-theme firefox-esr

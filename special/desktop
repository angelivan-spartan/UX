echo "[*] Configuring LXQt..."
PCMANFM_DIR="/etc/xdg/pcmanfm-qt/lxqt"
mkdir -p "$PCMANFM_DIR"
cat > "$PCMANFM_DIR/settings.conf" << EOF
[General]
terminal=qterminal

[Desktop]
wallpaper=$WALLPAPER
wallpaperMode=1
bgColor=#000000
EOF

# Apply pcmanfm-qt settings to user dirs (user config takes precedence over /etc/xdg)
for PCMANFM_UCONF_DIR in /root/.config/pcmanfm-qt/lxqt /etc/skel/.config/pcmanfm-qt/lxqt; do
    mkdir -p "$PCMANFM_UCONF_DIR"
    cp "$PCMANFM_DIR/settings.conf" "$PCMANFM_UCONF_DIR/settings.conf"
done

# libfm-qt (the file-op library used by pcmanfm-qt) reads the terminal
# setting from its own config, not from pcmanfm's settings.conf.
LIBFM_CONF_DIR="/etc/xdg/libfm-qt"
mkdir -p "$LIBFM_CONF_DIR"
cat > "$LIBFM_CONF_DIR/libfm-qt.conf" << 'EOF'
[General]
terminal=qterminal
EOF

for LIBFM_UCONF_DIR in /root/.config/libfm-qt /etc/skel/.config/libfm-qt; do
    mkdir -p "$LIBFM_UCONF_DIR"
    cp "$LIBFM_CONF_DIR/libfm-qt.conf" "$LIBFM_UCONF_DIR/libfm-qt.conf"
done

PANEL_DIR="/etc/xdg/lxqt"
mkdir -p "$PANEL_DIR"
PANEL_CONF="$PANEL_DIR/panel.conf"

update_ini_value() {
    # update_ini_value <file> <section> <key> <value>
    local file="$1" section="$2" key="$3" value="$4"
    python3 - <<PYEOF
import re, os

file = "$file"
section = "$section"
key = "$key"
value = "$value"

lines = open(file).readlines() if os.path.exists(file) else []

in_section = False
key_found  = False
out        = []

for line in lines:
    if re.match(r'^\[' + re.escape(section) + r'\]', line):
        in_section = True
        out.append(line)
        continue
    if in_section and re.match(r'^\[', line):
        if not key_found:
            out.append(key + '=' + value + '\n')
        in_section = False
    if in_section and re.match(r'^' + re.escape(key) + r'\s*=', line):
        out.append(key + '=' + value + '\n')
        key_found = True
        continue
    out.append(line)

if in_section and not key_found:
    out.append(key + '=' + value + '\n')

if not any(re.match(r'^\[' + re.escape(section) + r'\]', l) for l in lines):
    out.append('\n[' + section + ']\n')
    out.append(key + '=' + value + '\n')

os.makedirs(os.path.dirname(file), exist_ok=True)
open(file, 'w').writelines(out)
PYEOF
}

# Ensure a minimal panel.conf exists with mainmenu plugin listed
if [ ! -f "$PANEL_CONF" ]; then
    cat > "$PANEL_CONF" << EOF
[panel1]
plugins=mainmenu, taskbar, tray, clock

[mainmenu]
type=mainmenu
ownIcon=true
icon=$START_ICON
menu_file=/etc/xdg/menus/lxde-applications.menu
EOF
else
    update_ini_value "$PANEL_CONF" "mainmenu" "type" "mainmenu"
    update_ini_value "$PANEL_CONF" "mainmenu" "ownIcon" "true"
    update_ini_value "$PANEL_CONF" "mainmenu" "icon" "$START_ICON"
    update_ini_value "$PANEL_CONF" "mainmenu" "menu_file" "/etc/xdg/menus/lxde-applications.menu"
fi

# Apply panel.conf to user dirs (lxqt-panel reads user config first)
for LXQT_PANEL_UCONF_DIR in /root/.config/lxqt /etc/skel/.config/lxqt; do
    mkdir -p "$LXQT_PANEL_UCONF_DIR"
    if [ ! -f "$LXQT_PANEL_UCONF_DIR/panel.conf" ]; then
        cp "$PANEL_CONF" "$LXQT_PANEL_UCONF_DIR/panel.conf"
    else
        update_ini_value "$LXQT_PANEL_UCONF_DIR/panel.conf" "mainmenu" "type" "mainmenu"
        update_ini_value "$LXQT_PANEL_UCONF_DIR/panel.conf" "mainmenu" "ownIcon" "true"
        update_ini_value "$LXQT_PANEL_UCONF_DIR/panel.conf" "mainmenu" "icon" "$START_ICON"
        update_ini_value "$LXQT_PANEL_UCONF_DIR/panel.conf" "mainmenu" "menu_file" "/etc/xdg/menus/lxde-applications.menu"
    fi
done

# ── LXQt appearance: Arch-Colors theme + GNOME icons ────────────────────────
echo "[*] Configuring LXQt theme and icon theme..."
LXQT_GLOBAL_CONF="$PANEL_DIR/lxqt.conf"

if [ ! -f "$LXQT_GLOBAL_CONF" ]; then
    cat > "$LXQT_GLOBAL_CONF" << EOF
[General]
icon_theme=gnome
theme=Arch-Colors
EOF
else
    update_ini_value "$LXQT_GLOBAL_CONF" "General" "icon_theme" "gnome"
    update_ini_value "$LXQT_GLOBAL_CONF" "General" "theme" "Arch-Colors"
fi

# Apply to root and skel so it takes effect immediately (user config overrides /etc/xdg)
for LXQT_UCONF_DIR in /root/.config/lxqt /etc/skel/.config/lxqt; do
    mkdir -p "$LXQT_UCONF_DIR"
    if [ ! -f "$LXQT_UCONF_DIR/lxqt.conf" ]; then
        cp "$LXQT_GLOBAL_CONF" "$LXQT_UCONF_DIR/lxqt.conf"
    else
        update_ini_value "$LXQT_UCONF_DIR/lxqt.conf" "General" "icon_theme" "gnome"
        update_ini_value "$LXQT_UCONF_DIR/lxqt.conf" "General" "theme" "Arch-Colors"
    fi
done

# ── qterminal defaults ───────────────────────────────────────────────────────
echo "[*] Configuring qterminal..."
# qterminal uses QSettings with no org-name → config file is qterminal.ini (not qterminal.org/)
QTERMINAL_CONF="/etc/xdg/qterminal.ini"
cat > "$QTERMINAL_CONF" << 'EOF'
[General]
colorScheme=Linux
TerminalTransparency=2
EOF

for QT_UCONF_DIR in /root/.config /etc/skel/.config; do
    mkdir -p "$QT_UCONF_DIR"
    cp "$QTERMINAL_CONF" "$QT_UCONF_DIR/qterminal.ini"
done

# Set qterminal as the system-wide default terminal emulator
update-alternatives --set x-terminal-emulator /usr/bin/qterminal 2>/dev/null || \
    update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator \
        /usr/bin/qterminal 50

# ── Propagate all configs to existing user homes ──────────────────────────────
echo "[*] Propagating configs to existing user homes..."
for USER_HOME in /home/*/; do
    [ -d "$USER_HOME" ] || continue

    # pcmanfm-qt (wallpaper + terminal-in-context-menu)
    UPCMANFM="${USER_HOME}.config/pcmanfm-qt/lxqt"
    mkdir -p "$UPCMANFM"
    cp "$PCMANFM_DIR/settings.conf" "$UPCMANFM/settings.conf"

    # libfm-qt (terminal for Open-Terminal-Here)
    ULIBFM="${USER_HOME}.config/libfm-qt"
    mkdir -p "$ULIBFM"
    cp "$LIBFM_CONF_DIR/libfm-qt.conf" "$ULIBFM/libfm-qt.conf"

    # lxqt (theme + icons)
    ULXQT="${USER_HOME}.config/lxqt"
    mkdir -p "$ULXQT"
    if [ ! -f "$ULXQT/lxqt.conf" ]; then
        cp "$LXQT_GLOBAL_CONF" "$ULXQT/lxqt.conf"
    else
        update_ini_value "$ULXQT/lxqt.conf" "General" "icon_theme" "gnome"
        update_ini_value "$ULXQT/lxqt.conf" "General" "theme" "Arch-Colors"
    fi

    # panel (mainmenu icon + menu file)
    if [ ! -f "$ULXQT/panel.conf" ]; then
        cp "$PANEL_CONF" "$ULXQT/panel.conf"
    else
        update_ini_value "$ULXQT/panel.conf" "mainmenu" "type" "mainmenu"
        update_ini_value "$ULXQT/panel.conf" "mainmenu" "ownIcon" "true"
        update_ini_value "$ULXQT/panel.conf" "mainmenu" "icon" "$START_ICON"
        update_ini_value "$ULXQT/panel.conf" "mainmenu" "menu_file" "/etc/xdg/menus/lxde-applications.menu"
    fi

    # qterminal
    cp "$QTERMINAL_CONF" "${USER_HOME}.config/qterminal.ini"

    # Fix ownership of everything we just wrote
    chown -R --reference="$USER_HOME" "${USER_HOME}.config" 2>/dev/null || true
done

# ── 5. GRUB background ────────────────────────────────────────────────────────
echo "[*] Configuring GRUB background..."
GRUB_DEFAULTS="/etc/default/grub"

# Remove any existing GRUB_BACKGROUND line and append the new one
sed -i '/^GRUB_BACKGROUND=/d' "$GRUB_DEFAULTS"
echo "GRUB_BACKGROUND=\"$WALLPAPER\"" >> "$GRUB_DEFAULTS"

if [ -f "$WALLPAPER" ]; then
    update-grub
    echo "    GRUB background set to $WALLPAPER"
else
    echo "    WARNING: $WALLPAPER not found yet — GRUB_BACKGROUND configured,"
    echo "    run 'update-grub' after placing the image."
fi


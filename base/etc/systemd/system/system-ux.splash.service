[Unit]
Description=System-UX.splash Service
Before=local-fs.target
After=local-fs-pre.target
DefaultDependencies=no
ConditionPathExists=/usr/src/UX/res/logo/uxsplash.png

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/bin/fbi -noverbose -d /dev/fb0 -a /usr/src/UX/res/logo/uxsplash.png
StandardInput=tty
StandardOutput=tty
Restart=no

[Install]
WantedBy=local-fs-pre.target

